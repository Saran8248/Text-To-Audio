{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://text-to-audio-backend-9o8b.onrender.com/api/$1"
    },
    {
      "source": "/health",
      "destination": "https://text-to-audio-backend-9o8b.onrender.com/health"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
