NODE_ENV=development
PORT=5000 

# Local Python executable. Render Docker uses /usr/bin/python3.
PYTHON_EXECUTABLE=python

# Comma-separated browser origins allowed to call this API.
# Production example: https://your-vercel-app.vercel.app
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Optional first admin bootstrap. Set these in Render environment variables,
# not in committed source files.
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=
REQUIRE_ADMIN_APPROVAL=false
SESSION_TTL_DAYS=30
